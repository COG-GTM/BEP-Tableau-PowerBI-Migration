      <column caption='Quadrant Color' datatype='string' name='[Calculation_2330612859083718658]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2330612859080679425] &gt;= [Parameters].[Parameter 3] AND AVG([Discount]) &gt;= [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Upper Right&apos;&#13;&#10;ELSEIF [Calculation_2330612859080679425] &gt;= [Parameters].[Parameter 3] AND AVG([Discount]) &lt; [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Upper Left&apos;&#13;&#10;ELSEIF [Calculation_2330612859080679425] &lt; [Parameters].[Parameter 3] AND AVG([Discount]) &gt;= [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Bottom Right&apos;&#13;&#10;ELSE &apos;Bottom Left&apos;&#13;&#10;END' />
      </column>
      <column caption='KPI Colors' datatype='string' name='[Calculation_746753165445988354]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 50000 THEN &quot;Green&quot;&#13;&#10;ELSEIF  SUM([Sales]) &lt;= 50000 AND SUM([Sales]) &gt; 10000 THEN &quot;Orange&quot;&#13;&#10;ELSE &quot;Red&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI Colors of Two Years' datatype='string' name='[Calculation_746753165451341831]' role='measure' type='nominal'>
