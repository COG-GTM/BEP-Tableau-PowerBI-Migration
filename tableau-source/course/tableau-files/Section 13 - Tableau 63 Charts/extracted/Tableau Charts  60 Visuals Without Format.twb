    <worksheet name='Quadrant  (Dynamic)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='14'>Quadrant Chart (Dynamic)</run>
          </formatted-text>
        </title>
      </layout-options>
      <repository-location derived-from='https://localhost/workbooks/TableauCharts60VisualsWithoutFormat/84460028?rev=' id='QuadrantDynamic' path='/workbooks/TableauCharts60VisualsWithoutFormat' revision='' />
      <table>
        <view>
          <datasources>
            <datasource caption='Big Data Source' name='federated.1hpyone17bxgk51b0kg750hoe27w' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Discount' datatype='real' default-format='p0%' name='[Parameter 2]' param-domain-type='any' role='measure' type='quantitative' value='0.18'>
              <calculation class='tableau' formula='0.18' />
            </column>
            <column caption='Select Profit Ratio' datatype='real' default-format='p0%' name='[Parameter 3]' param-domain-type='any' role='measure' type='quantitative' value='0.1'>
              <calculation class='tableau' formula='0.1' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.1hpyone17bxgk51b0kg750hoe27w'>
            <column caption='Profit Ratio' datatype='real' name='[Calculation_2330612859080679425]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Profit])/ SUM([Sales])' />
            </column>
            <column caption='Quadrant Color' datatype='string' name='[Calculation_2330612859083718658]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_2330612859080679425] &gt;= [Parameters].[Parameter 3] AND AVG([Discount]) &gt;= [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Upper Right&apos;&#13;&#10;ELSEIF [Calculation_2330612859080679425] &gt;= [Parameters].[Parameter 3] AND AVG([Discount]) &lt; [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Upper Left&apos;&#13;&#10;ELSEIF [Calculation_2330612859080679425] &lt; [Parameters].[Parameter 3] AND AVG([Discount]) &gt;= [Parameters].[Parameter 2]&#13;&#10;THEN &apos;Bottom Right&apos;&#13;&#10;ELSE &apos;Bottom Left&apos;&#13;&#10;END' />
            </column>
            <column caption='Customer ID' datatype='integer' name='[Customer_ID]' role='dimension' type='ordinal' />
            <column datatype='real' name='[Discount]' role='measure' type='quantitative' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
