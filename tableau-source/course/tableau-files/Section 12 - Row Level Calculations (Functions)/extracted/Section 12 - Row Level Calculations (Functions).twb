      <aliases enabled='yes' />
      <column caption='Days to Ship' datatype='integer' name='[Calculation_1613977548030509058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&quot;day&quot;, [Order_Date], [Shipping_Date])' />
      </column>
      <column caption='Product (Replace)' datatype='string' name='[Calculation_1791306783167979555]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='REPLACE([Product_Name], &quot;#&quot;, &quot;Nr.&quot;)' />
      </column>
      <column caption='Products (Startswith Apple)' datatype='boolean' name='[Calculation_2251518369920303115]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STARTSWITH([Product_Name], &quot;Apple&quot;)' />
      </column>
      <column caption='Products (Contains Apple)' datatype='boolean' name='[Calculation_2251518369921073165]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([Product_Name], &quot;Apple&quot;)' />
      </column>
      <column caption='Products (Endswith Apple)' datatype='boolean' name='[Calculation_2251518369922387982]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='ENDSWITH([Product_Name], &quot;Apple&quot;)' />
      </column>
      <column caption='Products (Contains Samsung)' datatype='boolean' name='[Calculation_2251518369924599826]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([Product_Name], &quot;Samsung&quot;)' />
      </column>
      <column caption='Products (Black)' datatype='boolean' name='[Calculation_2251518369930805276]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS(LOWER([Product_Name]), &quot;black&quot;)' />
      </column>
      <column caption='Companies' datatype='string' name='[Calculation_2251518369935290409]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS(LOWER([Product_Name]), &quot;apple&quot;) THEN &quot;Apple&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([Product_Name]), &quot;samsung&quot;) THEN &quot;Samsung&quot;&#13;&#10;ELSEIF CONTAINS(LOWER([Product_Name]), &quot;microsoft&quot;) THEN &quot;Microsoft&quot;&#13;&#10;ELSE &quot;Unknown&quot;&#13;&#10;END' />
      </column>
      <column caption='Country (Abb U)' datatype='string' name='[Calculation_2424625480234987532]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Country] = &quot;France&quot;&#13;&#10;Then &quot;FR&quot;&#13;&#10;ELSEIF [Country] = &quot;Germany&quot;&#13;&#10;THEN &quot;DE&quot;&#13;&#10;ELSEIF [Country] = &quot;Italy&quot;&#13;&#10;THEN &quot;IT&quot;&#13;&#10;ELSE &quot;US&quot;&#13;&#10;END' />
      </column>
      <column caption='Country (Abb L)' datatype='string' name='[Calculation_2424625480235474957]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LOWER([Calculation_2424625480234987532])' />
      </column>
      <column caption='Order Date (Month)' datatype='string' name='[Calculation_278097305849282560]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT(DATENAME(&quot;month&quot;, [Order_Date]),3 )' />
      </column>
      <column caption='Order Date (Trunc)' datatype='date' datatype-customized='true' name='[Calculation_278097305849966595]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATETRUNC(&quot;month&quot;, [Order_Date]))' />
      </column>
      <column caption='Shipping Date (+2 Years)' datatype='datetime' name='[Calculation_278097305851363332]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATEADD(&quot;year&quot;,2,[Shipping_Date])' />
      </column>
      <column caption='Today' datatype='date' name='[Calculation_278097305851805701]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='TODAY()' />
      </column>
      <column caption='Now' datatype='datetime' name='[Calculation_278097305851850758]' role='dimension' type='ordinal'>
