      </column>
      <column caption='KPI (Colors)' datatype='string' name='[Calculation_278097305855582225]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Sales]) &gt; 200000 THEN &quot;green&quot;&#13;&#10;ELSEIF SUM([Sales]) &gt; 100000 THEN &quot;organge&quot;&#13;&#10;ELSEIF SUM([Sales]) &lt;= 100000 THEN &quot;red&quot;&#13;&#10;END' />
      </column>
      <column caption='Sales (AND)' datatype='real' name='[Calculation_278097305856720914]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Country] = &quot;Germany&quot; AND [Score] &gt; 50&#13;&#10;THEN [Sales]&#13;&#10;END' />
      </column>
      <column caption='Sales (Country)' datatype='real' name='[Calculation_278097305857363988]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Country] = &quot;Germany&quot; OR [Country] = &quot;France&quot;&#13;&#10;THEN [Sales]&#13;&#10;END' />
      </column>
      <column caption='Sales (Not Germany)' datatype='real' name='[Calculation_278097305857642517]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF NOT [Country] = &quot;Germany&quot;&#13;&#10;THEN [Sales]&#13;&#10;END' />
