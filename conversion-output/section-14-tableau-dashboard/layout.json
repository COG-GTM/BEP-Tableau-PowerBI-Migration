{
  "$schema": "powerbi-layout/1.0",
  "config": {
    "version": "5.50"
  },
  "pages": [
    {
      "name": "Sales Dashboard",
      "displayName": "Sales Dashboard",
      "width": 1280,
      "height": 720,
      "visuals": [
        {
          "name": "map_visual",
          "type": "map",
          "title": "Sales by Geography",
          "x": 0,
          "y": 0,
          "width": 640,
          "height": 360,
          "dataFields": {
            "location": "Orders[Country]",
            "size": "Orders[Sales]"
          }
        },
        {
          "name": "bar_category",
          "type": "clusteredBarChart",
          "title": "Sales by Category",
          "x": 640,
          "y": 0,
          "width": 640,
          "height": 360,
          "dataFields": {
            "axis": "Orders[Category]",
            "values": "[Total Sales]"
          }
        },
        {
          "name": "bar_subcategory",
          "type": "clusteredBarChart",
          "title": "Sales by Sub-Category",
          "x": 0,
          "y": 360,
          "width": 640,
          "height": 360,
          "dataFields": {
            "axis": "Orders[Sub-Category]",
            "values": "[Total Sales]"
          },
          "conditionalFormatting": {
            "rule": "[Logic 400] = TRUE",
            "color": "#E15759"
          }
        },
        {
          "name": "line_trend",
          "type": "lineChart",
          "title": "Sales Over Time",
          "x": 640,
          "y": 360,
          "width": 640,
          "height": 360,
          "dataFields": {
            "axis": "Date[Date]",
            "values": "[Total Sales]"
          }
        },
        {
          "name": "slicer_segment",
          "type": "slicer",
          "title": "Segment",
          "x": 0,
          "y": 0,
          "width": 200,
          "height": 60,
          "dataFields": {
            "field": "Orders[Segment]"
          }
        },
        {
          "name": "slicer_region",
          "type": "slicer",
          "title": "Region",
          "x": 200,
          "y": 0,
          "width": 200,
          "height": 60,
          "dataFields": {
            "field": "Orders[Region]"
          }
        }
      ],
      "interactions": {
        "crossFilter": true,
        "crossHighlight": true
      }
    }
  ]
}