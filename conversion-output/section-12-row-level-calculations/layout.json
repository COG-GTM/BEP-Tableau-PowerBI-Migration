{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "config": {
    "version": "5.0",
    "themeCollection": {
      "baseTheme": {
        "name": "Tableau10",
        "reportVersionAtImport": "5.0"
      }
    }
  },
  "pages": [
    {
      "name": "Lower, Upper 2",
      "displayName": "Lower, Upper 2",
      "displayOption": "FitToPage",
      "width": 1280,
      "height": 720,
      "visuals": [
        {
          "id": "vis_calc_types",
          "type": "tableEx",
          "title": "Calculation Types",
          "x": 0,
          "y": 0,
          "width": 640,
          "height": 360,
          "fields": [
            "Products[Product Name]",
            "Products (Lower)",
            "Products (Upper)",
            "Products (Len)",
            "Products (Trim)",
            "Products (CountD)"
          ]
        },
        {
          "id": "vis_ceiling_floor",
          "type": "tableEx",
          "title": "Ceiling / Floor / Round",
          "x": 640,
          "y": 0,
          "width": 640,
          "height": 360,
          "fields": [
            "Orders[Sales]",
            "Sales (Ceiling)",
            "Sales (Floor)",
            "Sales (Round)",
            "Sales (Round1)"
          ]
        },
        {
          "id": "vis_concat_fullname",
          "type": "tableEx",
          "title": "Concat Full Name",
          "x": 0,
          "y": 360,
          "width": 320,
          "height": 180,
          "fields": [
            "Customers[First Name]",
            "Customers[Last Name]",
            "Full Name"
          ]
        },
        {
          "id": "vis_concat_product",
          "type": "tableEx",
          "title": "Concat Product",
          "x": 320,
          "y": 360,
          "width": 320,
          "height": 180,
          "fields": [
            "Products[Category]",
            "Products[Product Name]",
            "Full Product Name"
          ]
        },
        {
          "id": "vis_datediff",
          "type": "tableEx",
          "title": "DateDiff",
          "x": 640,
          "y": 360,
          "width": 320,
          "height": 180,
          "fields": [
            "Orders[Order Date]",
            "Orders[Ship Date]",
            "Days to Ship"
          ]
        },
        {
          "id": "vis_extract_dates",
          "type": "tableEx",
          "title": "Extract Dates",
          "x": 960,
          "y": 360,
          "width": 320,
          "height": 180,
          "fields": [
            "Orders[Order Date]",
            "Order Date (Month)",
            "Order Date (Year)",
            "Order Date (Quarter)",
            "Order Date (Trunc)"
          ]
        },
        {
          "id": "vis_find",
          "type": "tableEx",
          "title": "Find / FindNth",
          "x": 0,
          "y": 540,
          "width": 640,
          "height": 180,
          "fields": [
            "Customers[Phone]",
            "Phone (Find -)",
            "Phone (FindNth2)",
            "Phone (Country Code Find)"
          ]
        },
        {
          "id": "vis_format_date",
          "type": "tableEx",
          "title": "Format Date",
          "x": 640,
          "y": 540,
          "width": 640,
          "height": 180,
          "fields": [
            "Orders[Order Date]",
            "Shipping Date (+2 Years)",
            "Today",
            "Now"
          ]
        }
