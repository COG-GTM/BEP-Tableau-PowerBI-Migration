// Tableau: RUNNING_SUM(SUM([Calculation_278097305858076694]))
Running Total Revenue = 
    VAR CurrentDate = MAX(Orders[Order Date])
    RETURN
        CALCULATE(
            SUM(Orders[Sales]),
            FILTER(ALL(Orders[Order Date]), Orders[Order Date] <= CurrentDate)
        )

