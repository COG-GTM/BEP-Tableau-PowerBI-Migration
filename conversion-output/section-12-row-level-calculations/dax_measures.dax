// Tableau: IF CONTAINS(LOWER([Product_Name]), "apple") THEN "Apple" ELSEIF CONTAINS(LOWER([Product_Name]), "samsung") THEN "Samsung" ELSEIF CONTAINS(LOWER([Product_Name]), "microsoft") THEN "Microsoft" ELS...
Companies = 
    // Original: IF CONTAINS(LOWER([Product_Name]), "apple") THEN "Apple"
ELSEIF CONTAINS(LOWER([Product_Name]), "samsung") THEN "Samsung"
ELSEIF CONTAINS(LOWER([Product_Name]), "microsoft") THEN "Microsoft"
ELSE "Unknown"
END
    IF(/* condition */, /* true_val */, /* false_val */)

