            lineageTag: 064fd054-e7da-acfe-5b6b-9ba92f523b7e

        measure 'Products (Contains Apple)' =
            // Original: CONTAINS([Product_Name], "Apple")
            CONTAINSSTRING(Orders[Column], "search_text")
            lineageTag: 48baf023-bc8e-7634-5de3-2d0fb8c7b6c2

        measure 'Products (Endswith Apple)' =
            // Original Tableau: ENDSWITH([Product_Name], "Apple")
