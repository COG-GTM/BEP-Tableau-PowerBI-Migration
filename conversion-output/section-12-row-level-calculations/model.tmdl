            SUM(Orders[Sales])
            lineageTag: df6c7929-1824-3807-b0b6-6f8b57b0609e

        measure 'Today' =
            // Original: TODAY()
            DAY(Orders[Order Date])
            lineageTag: 8483334e-a0c1-a1dd-e426-3bfabcc020ab

        measure 'Now' =
