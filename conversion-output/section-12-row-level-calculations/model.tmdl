            IF(ISBLANK(/* expr */), 0, /* expr */)
            lineageTag: 03cb3153-a409-738e-e474-4c247900e673

        measure 'Profit (IFNULL)' =
            // Original: IFNULL([Profit],1)
            IF(ISBLANK(/* expr */), /* replacement */, /* expr */)
            lineageTag: 0075a4fc-51b5-c358-4e8b-f7091fa8924e

        measure 'Customer Email (IFNULL)' =
