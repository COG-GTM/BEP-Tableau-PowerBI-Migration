            lineageTag: 68251ebe-d312-220a-cb93-28653ab1c3a3
            summarizeBy: none
            sourceColumn: Product Name

        column 'Sales'
            dataType: double
            formatString: \$#,0.00;(\$#,0.00);\$#,0.00
