            summarizeBy: sum
            sourceColumn: Profit

        // --- ALL DAX MEASURES ---

        measure 'Products (Lower)' =
            // Original: LOWER([Product1])
            LOWER(Orders[Column])
            lineageTag: c27b2f82-1a70-75d4-3ee1-2faaabab06a9

        measure 'Products (Upper)' =
            // Original: UPPER([Product1])
            UPPER(Orders[Column])
