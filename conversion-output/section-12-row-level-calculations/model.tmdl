            lineageTag: 85856e6e-008a-9833-1afc-4599f0212693

        measure 'Products (Contains Samsung)' =
            // Original: CONTAINS([Product_Name], "Samsung")
            CONTAINSSTRING(Orders[Column], "search_text")
            lineageTag: 5241e1c9-7bbb-bea0-2358-205c620651db

        measure 'Products (Black)' =
            // Original: CONTAINS(LOWER([Product_Name]), "black")
            LOWER(Orders[Column])
            lineageTag: 50ab25e0-c554-b234-8a62-9f8eeed1e44c

        measure 'Companies' =
            // Original: IF CONTAINS(LOWER([Product_Name]), "apple") THEN "Apple"
            ELSEIF CONTAINS(LOWER([Product_Name]), "samsung") THEN "Samsung"
            ELSEIF CONTAINS(LOWER([Product_Name]), "microsoft") THEN "Microsoft"
            ELSE "Unknown"
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: ee65cb27-b960-af85-5dcd-09ffd79fe0e3

        measure 'Country (Abb U)' =
            // Original: IF [Country] = "France"
            Then "FR"
            ELSEIF [Country] = "Germany"
            THEN "DE"
            ELSEIF [Country] = "Italy"
            THEN "IT"
            ELSE "US"
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 0e9d77a4-3979-d6e6-0ba9-557cbee9b7f2

        measure 'Country (Abb L)' =
            // Original: LOWER([Calculation_2424625480234987532])
            LOWER(Orders[Column])
            lineageTag: bcf2c666-e005-e8d5-31e7-88581f64b2b5

        measure 'Order Date (Month)' =
            // Original: LEFT(DATENAME("month", [Order_Date]),3 )
            LEFT(Orders[Column])
            lineageTag: 851d902e-ae7b-1fc1-0338-1ec682e44e2a

        measure 'Order Date (Trunc)' =
            // Original Tableau: DATE(DATETRUNC("month", [Order_Date]))
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: 1c757fa5-32cd-5e03-0c95-27f0ff99133d

        measure 'Shipping Date (+2 Years)' =
            // Original Tableau: DATEADD("year",2,[Shipping_Date])
