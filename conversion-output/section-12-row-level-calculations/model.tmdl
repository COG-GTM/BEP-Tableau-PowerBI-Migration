            SUM(Orders[Sales])
            lineageTag: 99972248-fda1-7eae-d0d2-4c22f89071b4

        measure 'Running Total Revenue' =
            VAR CurrentDate = MAX(Orders[Order Date])
            RETURN
            CALCULATE(
            SUM(Orders[Sales]),
            FILTER(ALL(Orders[Order Date]), Orders[Order Date] <= CurrentDate)
            )
            lineageTag: 4b99ce0a-c984-7792-3716-21ef5c469118

        measure 'Total Revenue' = SUM(Orders[Calculation_278097305858076694])
            lineageTag: 5ef9a3bf-d2cc-a6af-62ea-6187368e8ae4

        measure 'Country (IF, ELSE)' =
