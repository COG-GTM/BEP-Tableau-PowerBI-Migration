            SUM(Orders[Sales])
            lineageTag: 81a3f8b0-4196-64b8-761e-4e62e05acc69

        measure 'KPI (Colors)' =
            // Original: IF SUM([Sales]) > 200000 THEN "green"
            ELSEIF SUM([Sales]) > 100000 THEN "organge"
            ELSEIF SUM([Sales]) <= 100000 THEN "red"
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 8ee0712a-1b0f-373a-aa79-73b5e9ee98b8

        measure 'Sales (AND)' =
            // Original: IF [Country] = "Germany" AND [Score] > 50
