            lineageTag: 489a3abb-b408-3063-fbd8-d07c2b533179
            summarizeBy: none
            sourceColumn: Product Name

        column 'Sales'
            dataType: double
            formatString: \$#,0.00;(\$#,0.00);\$#,0.00
            lineageTag: 2c8b111d-3f99-a6b3-cf75-700abc4a5e7e
            summarizeBy: sum
            sourceColumn: Sales

        column 'Quantity'
            dataType: int64
            formatString: 0
