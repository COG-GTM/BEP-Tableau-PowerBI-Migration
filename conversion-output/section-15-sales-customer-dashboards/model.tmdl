        column 'City'
            dataType: string
            lineageTag: d14f2dbb-9400-e4f2-3df3-263a879fad37
            summarizeBy: none
            sourceColumn: City

        column 'State'
            dataType: string
            lineageTag: 46ca74a5-3db3-d848-96a2-041db5d536b8
            summarizeBy: none
            sourceColumn: State

        column 'Postal Code'
            dataType: int64
            formatString: 0
            lineageTag: 656437ca-bfef-d7b2-7fae-58a7e7e26d33
            summarizeBy: none
