            summarizeBy: none
            sourceColumn: Ship Date

        column 'Ship Mode'
            dataType: string
            lineageTag: 991de78a-5299-eb35-d5b9-a3fdaa408e59
            summarizeBy: none
            sourceColumn: Ship Mode

        column 'Customer ID'
            dataType: string
            lineageTag: 5dbde63a-c612-ca33-7ea6-07f443f7d3cf
            summarizeBy: none
            sourceColumn: Customer ID

        column 'Segment'
            dataType: string
            lineageTag: 3dec37ea-7481-1204-f281-dab13cb9624a
            summarizeBy: none
