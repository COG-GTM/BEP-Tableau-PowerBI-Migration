            summarizeBy: sum
            sourceColumn: Profit

        // --- ALL DAX MEASURES ---

        measure '% Diff Orders' = DISTINCTCOUNT(Orders[CY Sales (copy)_3221481164594982929])
            lineageTag: a05360d8-86d3-5e24-a4f7-3ec9cd5686a7

        measure '% Diff Customers' = DISTINCTCOUNT(Orders[CY Sales (copy)_3221481164532666369])
            lineageTag: 8ed5fd84-bacf-0f92-68a1-4d2696810ca8

        measure '% Diff Quantity' =
            // Original Tableau: (SUM([CY Sales (copy) (copy)_237846410424193025]) - SUM([PY Sales (copy) (copy)_237846410424823811])) / SUM([PY Sales (copy) (copy)_237846410424823811])
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: c7e1393f-2360-ca08-fdfb-d9dba7c1da6b

        measure '% Diff Profit' =
            // Original Tableau: (SUM([CY Sales (copy)_237846410424180736]) - SUM([PY Sales (copy)_237846410424815618])) / SUM([CY Sales (copy)_237846410424180736])
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: 6e2143d7-e3d2-1664-da27-00b3e3083fdb

        measure '% Diff Sales per Customers' =
            // Original Tableau: ([CY Profit (copy)_3221481164532895746] - [CY Sales per Customer (copy)_3221481164533485572]) / [CY Sales per Customer (copy)_3221481164533485572]
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: 4ea6ed60-449a-1233-17a9-79671035e79e

        measure 'PY Customers' =
            // Original: IF YEAR([Order Date])= [Parameters].[Parameter 1]-1 THEN [Customer ID]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 777df84b-f9c1-91d9-2365-67893cba548d

        measure 'CY Sales per Customer' = DISTINCTCOUNT(Orders[CY Sales (copy)_3221481164532666369])
            lineageTag: b14bc359-71e7-03b2-8818-1b331170df9a

        measure 'CY Quantity' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Quantity]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 5a49bfb9-e30b-2d95-ffbd-438ce178c16a

        measure 'CY Profit' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Profit]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 4f7f9bc0-5539-7aa9-6135-3331b166de77

        measure 'CY Customers' =
            // Original: IF YEAR([Order Date])= [Parameters].[Parameter 1] THEN [Customer ID]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 94d828a6-70f3-8cef-f559-008d6f0bc69e

        measure 'CY Orders' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Order ID]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: e7ece9ec-7618-4be2-18f1-c9b175b8db1e

        measure 'PY Sales' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Sales]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: b91dbf54-cc7f-1c41-3fc4-3d34d7f65634

        measure 'PY Sales per Customer' = DISTINCTCOUNT(Orders[CY Customers (copy)_3221481164533411843])
            lineageTag: 37b165b2-b941-f637-50fd-981e6992979c

        measure 'Current Year' =
            // Original Tableau: [Parameters].[Parameter 1]
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: 4ce633c0-5ae4-03d8-98ed-4aaef92aa5b0

        measure 'Previous Year' =
            // Original Tableau: [Parameters].[Parameter 1]-1
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: c467b002-20a2-dd18-fecc-b96304ba4275

        measure 'KPI CY Less PY' =
            // Original: IF SUM([Calculation_721701895334993921]) < SUM([CY Sales (copy)_721701895335804930]) THEN '⬤'
            ELSE ''
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 2ff788fe-c855-cb4e-faa3-c0a13a4adab1

        measure 'KPI Sales Avg' = AVERAGEX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: d1a3c7d7-b0be-b3fb-e1d4-289d628ae45c

        measure 'CY Sales' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Sales]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 3a13fd84-716d-6dc7-a90d-5c3896d019e4

        measure 'Order Date (Year)' =
            // Original: YEAR([Order Date])
            YEAR(Orders[Order Date])
            lineageTag: e4cb2c59-b964-8bd3-4a8a-ddb00c6cba09

        measure '% Diff Sales' =
            // Original Tableau: (SUM([Calculation_721701895334993921]) - SUM([CY Sales (copy)_721701895335804930])) / SUM([CY Sales (copy)_721701895335804930])
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: f33bda1c-b17f-5246-3a04-b95462c9876c

        measure 'Min/Max Sales' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: ae8eb9de-83c3-0f69-b9c6-9a88a64123ab

        measure '{SUM([CY Sales])}' =
            // Original Tableau: {SUM([Calculation_721701895334993921])}
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: 9b308c83-055b-ce5d-cf6b-ca985fdc08dd

        measure 'Nr of Orders per Customers' =
            CALCULATE(
            DISTINCTCOUNT(Orders[CY Sales (copy)_3221481164594982929]),
            ALLEXCEPT(Orders, Orders[CY Sales (copy)_3221481164532666369])
            )
            lineageTag: 755c2f9d-c71c-c917-a89a-e9c19f120b4f

        measure 'KPI Profit Avg' = AVERAGEX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: 9000d9b4-bdf9-6624-d9be-8e2925ddae0a

        measure 'Min/Max Sales Per Customers' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: 3c4cd9a5-04da-a96a-587c-1d3249aef0cb

        measure 'Min/Max Customers' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: f794edbb-80ed-7934-5d95-22af9e8ca149

        measure 'Min/Max Quantity' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: bd0d8ee2-ef1e-7e67-c564-a42aad3b21d2

        measure 'Min/Max Profit' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: 9c5ebc86-7b25-abc3-61fd-ac2e8e99c304

        measure 'Min/Max Orders' = MAXX(ALLSELECTED(Orders[Sub-Category]), [Total Sales])
            lineageTag: 693d3810-dfb8-12de-e056-498a861453a8

        measure 'PY Quantity' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Quantity]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 36c4ac04-e7e9-36e7-0e55-c1ad22ca51fc

        measure 'PY Profit' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Profit]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: b2d02e7f-ca19-8c14-8698-85627d6d3a3d

        measure 'PY Orders' =
            // Original: IF YEAR([Order Date]) = [Parameters].[Parameter 1]-1 THEN [Order ID]
            END
            IF(/* condition */, /* true_val */, /* false_val */)
            lineageTag: 70229f75-4558-e7a6-f577-8b072318d15b

        measure 'Select Year' =
            // Original Tableau: 2023
            // DAX equivalent (manual review recommended)
            SUM(Orders[Sales])
            lineageTag: f41880cb-baff-db28-e080-3cc4ef2e2047

    // ===========================================
    // DIMENSION TABLE: Customers
    // ===========================================

    table Customers
        lineageTag: f3069e7a-a36e-b7d1-152d-2a18377f1509

        partition Customers = m
            mode: import
            source =
                let
                    Source = Csv.Document(File.Contents("course/datasets/non-eu-dataset/small-dataset/Customers.csv"), [Delimiter=";", Encoding=65001, QuoteStyle=QuoteStyle.None]),
                    PromotedHeaders = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
                    ChangedTypes = Table.TransformColumnTypes(PromotedHeaders, {
                        {"Customer ID", type text},
                        {"Customer Name", type text}
                    })
                in
                    ChangedTypes

        column 'Customer ID'
            dataType: string
            lineageTag: 54904805-2000-ec06-1d07-1796cb2b12f7
            summarizeBy: none
            sourceColumn: Customer ID
            isKey: true

        column 'Customer Name'
            dataType: string
            lineageTag: cb05ae9f-2c98-b7a8-ad85-8ccd5041dca3
            summarizeBy: none
            sourceColumn: Customer Name

