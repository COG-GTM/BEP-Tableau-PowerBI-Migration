{
  "name": "Tableau10",
  "description": "Tableau 10 default color palette adapted for Power BI",
  "dataColors": [
    "#4E79A7",
    "#F28E2B",
    "#E15759",
    "#76B7B2",
    "#59A14F",
    "#EDC948",
    "#B07AA1",
    "#FF9DA7",
    "#9C755F",
    "#BAB0AC"
  ],
  "background": "#FFFFFF",
  "foreground": "#333333",
  "tableAccent": "#4E79A7",
  "visualStyles": {
    "*": {
      "*": {
        "general": [
          {
            "responsive": true
          }
        ],
        "title": [
          {
            "fontColor": {
              "solid": {
                "color": "#333333"
              }
            },
            "fontSize": 12
          }
        ],
        "labels": [
          {
            "fontColor": {
              "solid": {
                "color": "#666666"
              }
            },
            "fontSize": 10
          }
        ]
      }
    }
  }
}