// -----------------------------------------------
// CALCULATED FIELDS / MEASURES
// -----------------------------------------------

// Tableau: ZN(SUM([Sales])) - LOOKUP(ZN(SUM([Sales])), -1)
[Calculation1] = 
    CALCULATE(
        SUM(Orders[Sales]),
        DATEADD('Date'[Date], -1, YEAR)
    )

// Tableau: RUNNING_SUM(SUM([Sales]))
[Calculation2] = 
    VAR CurrentDate = MAX(Orders[Order Date])
    RETURN
        CALCULATE(
            SUM(Orders[Sales]),
            FILTER(ALL(Orders[Order Date]), Orders[Order Date] <= CurrentDate)
        )

// Tableau: RANK_PERCENTILE(SUM([Sales]))
[Calculation3] = 
    VAR CurrentVal = [Total Sales]
    VAR AllVals = ALLSELECTED(Orders[Sub-Category])
    VAR CountBelow = COUNTROWS(FILTER(AllVals, [Total Sales] < CurrentVal))
    VAR TotalCount = COUNTROWS(AllVals)
    RETURN
        DIVIDE(CountBelow, TotalCount - 1, 0)

// Tableau: ZN(SUM([Sales])) - LOOKUP(ZN(SUM([Sales])), -1)
[Calculation4] = 
    CALCULATE(
        SUM(Orders[Sales]),
        DATEADD('Date'[Date], -1, YEAR)
    )

// Tableau: (ZN([Calculation1]) - LOOKUP(ZN([Calculation1]), -1)) / ABS(LOOKUP(ZN([Calculation1]), -1))
[Calculation1 1] = 
    CALCULATE(
        SUM(Orders[Sales]),
        DATEADD('Date'[Date], -1, YEAR)
    )

// Tableau: RUNNING_SUM(SUM([Sales]))
[Calculation1] = 
    VAR CurrentDate = MAX(Orders[Order Date])
    RETURN
        CALCULATE(
            SUM(Orders[Sales]),
            FILTER(ALL(Orders[Order Date]), Orders[Order Date] <= CurrentDate)
        )

