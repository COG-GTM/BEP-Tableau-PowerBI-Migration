        DATEADD('Date'[Date], -1, YEAR)
    )

// Tableau: IF FIRST() = 0 THEN SUM([Sales]) END
First (Sales) = 
    // Original: IF FIRST() = 0 THEN SUM([Sales])
END
    IF(/* condition */, /* true_val */, /* false_val */)

// Tableau: RANK(SUM([Sales]))
Rank (Sales) = 
    RANKX(
        ALLSELECTED(Orders[Sub-Category]),
        [Total Sales],
        ,
        DESC,
        Dense
    )

// Tableau: LAST()
Last = 
    // Original Tableau: LAST()
