{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/fabric/item/report/definition/visualContainer/1.0.0/schema.json",
  "config": {
    "version": "5.0",
    "themeCollection": {
      "baseTheme": {
        "name": "Tableau10",
        "reportVersionAtImport": "5.0"
      }
    }
  },
  "pages": [
    {
      "name": "Dashboard 1",
      "displayName": "Dashboard 1",
      "displayOption": "FitToPage",
      "width": 1280,
      "height": 720,
      "visuals": [
        {
          "id": "vis_running_sum",
          "type": "lineChart",
          "title": "Running Sum of Sales",
          "x": 0,
          "y": 0,
          "width": 640,
          "height": 360,
          "fields": [
            "Orders[Order Date]",
            "Calculation2 (Running Sum)"
          ]
        },
        {
          "id": "vis_rank",
          "type": "clusteredBarChart",
          "title": "Rank of Sales by Sub-Category",
          "x": 640,
          "y": 0,
          "width": 640,
          "height": 360,
          "fields": [
            "Orders[Sub-Category]",
            "Rank_Sales",
            "SUM(Orders[Sales])"
          ]
        },
        {
          "id": "vis_period_diff",
          "type": "lineChart",
          "title": "Period-over-Period Difference",
          "x": 0,
          "y": 360,
          "width": 427,
          "height": 360,
          "fields": [
            "Orders[Order Date]",
            "Calculation1 (Period Diff)"
          ]
        },
        {
          "id": "vis_pct_change",
          "type": "lineChart",
          "title": "% Change from Previous Period",
          "x": 427,
          "y": 360,
          "width": 427,
          "height": 360,
          "fields": [
            "Orders[Order Date]",
            "Calculation1_1 (Pct Change)"
          ]
        },
        {
          "id": "vis_index_first_last",
          "type": "tableEx",
          "title": "Index / First / Last Positions",
          "x": 854,
          "y": 360,
          "width": 426,
          "height": 180,
          "fields": [
            "Orders[Sub-Category]",
            "Index_Pos",
            "First_Pos",
            "Last_Pos",
            "First_Sales"
          ]
        },
        {
          "id": "vis_running_sales",
          "type": "lineChart",
          "title": "Running Sales by Sub-Category",
          "x": 854,
          "y": 540,
          "width": 426,
          "height": 180,
          "fields": [
            "Orders[Sub-Category]",
            "Running_Sales"
          ]
        }
      ]
    }
  ]
}