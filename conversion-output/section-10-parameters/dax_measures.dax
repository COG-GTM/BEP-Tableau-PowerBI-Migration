// Tableau: Parameter 'Choose Dimension' (string, list: "Country", "Category")
// Power BI: Disconnected table with SELECTEDVALUE
Choose Dimension = {""Country"", ""Category""}
Choose Dimension Value = SELECTEDVALUE('Choose Dimension'[Value], ""Country"")

// Tableau: Parameter 'Choose Measure' (string, list: "Sales", "Profit", "Quantity")
// Power BI: Disconnected table with SELECTEDVALUE
Choose Measure = {""Sales"", ""Profit"", ""Quantity""}
Choose Measure Value = SELECTEDVALUE('Choose Measure'[Value], ""Sales"")

// Tableau: Parameter 'Choose Size of Bins' (real, range 5.0-25.0)
// Power BI: What-If parameter using GENERATESERIES
Choose Size of Bins = GENERATESERIES(5.0, 25.0, 1)
Choose Size of Bins Value = SELECTEDVALUE('Choose Size of Bins'[Choose Size of Bins], 20.)

// Tableau: Parameter 'Choose Threshold' (integer)
Choose Threshold Value = SELECTEDVALUE('Choose Threshold'[Choose Threshold])

// Tableau: Parameter 'Choose Top N Products' (integer, range 0-50)
// Power BI: What-If parameter using GENERATESERIES
Choose Top N Products = GENERATESERIES(0, 50, 1)
Choose Top N Products Value = SELECTEDVALUE('Choose Top N Products'[Choose Top N Products], 15)

