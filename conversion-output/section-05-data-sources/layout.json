{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/reportLayout/1.0.0/schema.json",
  "metadata": {
    "source": "Section 5 - Data Sources.twb",
    "conversion_date": "2026-04-01",
    "canvas_width": 1280,
    "canvas_height": 720,
    "description": "Power BI page layout for Section 05 - Data Sources. Single worksheet workbook with no dashboards."
  },
  "config": {
    "version": "5.50",
    "themeCollection": {
      "baseTheme": {
        "name": "section-05-theme",
        "reportVersionAtImport": "5.50",
        "type": 2
      }
    },
    "activeSectionIndex": 0,
    "defaultDrillFilterOtherVisuals": true
  },
  "pages": [
    {
      "name": "DataSourcesOverview",
      "displayName": "Data Sources Overview",
      "displayOption": "FitToPage",
      "width": 1280,
      "height": 720,
      "background": {
        "color": "#F5F5F5",
        "transparency": 0
      },
      "visuals": [
        {
          "name": "sales_bar_chart",
          "type": "clusteredBarChart",
          "description": "Sales by Category - demonstrates data source connectivity across joined CSV tables",
          "position": {
            "x": 10,
            "y": 10,
            "width": 620,
            "height": 340
          },
          "dataBindings": {
            "axis": "Products[Category]",
            "values": [
              "SUM(Orders[Sales])"
            ],
            "tooltips": [
              "SUM(Orders[Profit])",
              "SUM(Orders[Quantity])"
            ]
          },
          "config": {
            "title": "Sales by Category",
            "showDataLabels": true,
            "dataLabelFormat": "$#,0",
            "barColor": "#4E79A7"
          }
        },
        {
          "name": "sales_by_country_chart",
          "type": "clusteredColumnChart",
          "description": "Sales by Country - from joined Customers dimension",
          "position": {
            "x": 640,
            "y": 10,
            "width": 630,
            "height": 340
          },
          "dataBindings": {
            "axis": "Orders[Country]",
            "values": [
              "SUM(Orders[Sales])"
            ],
            "tooltips": [
              "SUM(Orders[Profit])"
            ]
          },
          "config": {
            "title": "Sales by Country",
            "showDataLabels": true,
            "barColor": "#F28E2B"
          }
        },
        {
          "name": "logic_400_table",
          "type": "table",
          "description": "Data table showing Logic 400 calculated column alongside Sales values",
          "position": {
            "x": 10,
            "y": 360,
            "width": 620,
            "height": 350
          },
          "dataBindings": {
            "columns": [
              {
                "field": "Orders[Order ID]",
                "title": "Order ID"
              },
              {
                "field": "Orders[Sales]",
                "title": "Sales",
                "format": "$#,0.00"
              },
              {
                "field": "Orders[Logic 400]",
                "title": "Logic 400 (Sales < 400)"
              },
              {
                "field": "Products[Category]",
                "title": "Category"
              }
            ]
          },
          "config": {
            "title": "Orders with Logic 400 Flag",
            "showGridLines": true,
            "alternateRowColor": "#F0F4F8"
          }
        },
        {
          "name": "profit_line_chart",
          "type": "lineChart",
          "description": "Profit trend over time from Orders fact table",
          "position": {
            "x": 640,
            "y": 360,
            "width": 630,
            "height": 350
          },
          "dataBindings": {
            "axis": "'Date'[Date]",
            "values": [
              "SUM(Orders[Profit])"
            ],
            "tooltips": [
              "SUM(Orders[Sales])"
            ]
          },
          "config": {
            "title": "Profit Trend Over Time",
            "xAxisGranularity": "month",
            "lineColor": "#4E79A7",
            "showDataPoints": false,
            "showArea": true,
            "areaTransparency": 80
          }
        }
      ]
    }
  ]
}